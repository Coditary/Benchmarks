{
  "language": "C",
  "implementation": "simple-loop",
  "run_cmd": "./bench {size}",
  "tags": [
    "compiled",
    "native",
    "gcc",
    "minimal"
  ],
  "hooks": {
    "install": "./install.sh",
    "build": "gcc -O3 -s -o bench main.c",
    "clean": "rm -f bench"
  },
  "source_files": [
    "main.c"
  ],
  "artifact_path": "bench",
  "notes": "Minimal C: heap int64 array, fill + sum loop. Built with gcc -O3 -s."
}
